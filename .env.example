# Google Maps Platform の API キー（キュー「Google Maps で取得」で使用）
# Maps JavaScript API と Places API を有効にしたキーを設定してください。
VITE_GOOGLE_MAPS_API_KEY=

# フルオート用サーバーURL（設定時のみキュー・ダッシュボードをAPIに連携）例: http://localhost:3001
VITE_API_URL=

# --- Vercel（本番）Edge middleware 用: webpage.closer-official.com の閲覧前門（HTTP Basic 認証）
# 両方とも空だと当該ホストでは認証をかけません。Vercel プロジェクトの Environment Variables に設定してください。
# WEBPAGE_BASIC_AUTH_USER=
# WEBPAGE_BASIC_AUTH_PASSWORD=
