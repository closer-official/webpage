{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api?_vp=$1" },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "supernihonshi.store-official.net" }],
      "destination": "/deliverables/japanese-history-higashi/index.html"
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "supernihonshi.store-official.net" }],
      "destination": "/deliverables/japanese-history-higashi/:path+"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/auto-process/tick", "schedule": "0 0 * * *" }
  ]
}
