{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/kodo-youtube-slideshow", "destination": "/kodo-youtube-slideshow/index.html" },
    { "source": "/kodo-youtube-slideshow/", "destination": "/kodo-youtube-slideshow/index.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/template-gallery", "destination": "/api?_vp=template-gallery" },
    { "source": "/api/(.*)", "destination": "/api?_vp=$1" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/auto-process/tick", "schedule": "0 0 * * *" }
  ]
}
