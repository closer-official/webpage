# サーバー用の環境変数（コピーして .env に）
# フルオートの「サーバーで収集」「キューを1件処理」はここを読む。ルートの .env だけでは動きません。
PORT=3001

# Google Maps Platform（Places API 用・サーバー側で検索）
# 値はルート .env の VITE_GOOGLE_MAPS_API_KEY と同じでOK
GOOGLE_MAPS_API_KEY=

# Google AI（Gemini）口コミ分析・DM文面生成用（AI Studio で発行）
GEMINI_API_KEY=

# Stripe 決済（設定時のみ「Stripeで支払う」が利用可能）
STRIPE_SECRET_KEY=

# 紹介コード（Supabase 未使用のローカル開発用のみ）。本番は Supabase の referral_codes テーブルで管理
# REFERRAL_CODES=TEST-CODE-1,DEV-ONLY

# 本番用: Supabase（設定時は JSON の代わりに Supabase に保存）
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# CRON_SECRET=任意（/api/auto-process/tick 保護用）
